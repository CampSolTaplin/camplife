---
import CarpoolAnim from './CarpoolAnim.astro';
---
<section class="section carpool" id="carpool">
  <div class="container">
    <div class="carpool-head reveal">
      <div class="section-head">
        <span class="eyebrow">First &amp; last impression, every day</span>
        <h2>Carpool &amp; <span class="hl">pickup.</span></h2>
        <p>Three locations, two windows, one promise — your camper is safe and accounted for, every moment.</p>
      </div>
      <div class="carpool-art">
        <img src="/assets/sunny-carpool2.png" alt="Sunny helping campers at carpool" loading="lazy" />
      </div>
    </div>
    <div class="cp-windows">
      <div class="cp-win morning reveal">
        <div class="lab">Morning Drop-off</div>
        <div class="time">8:30 – 9:00 AM</div>
        <ul>
          <li>Drive through, drop off, keep moving</li>
          <li>Parents stay in the vehicle at all times</li>
          <li>Hang tag on rear-view mirror</li>
          <li>Carpool is always at the location where your <strong>youngest sibling</strong> is registered</li>
        </ul>
      </div>
      <div class="cp-win afternoon reveal d1">
        <div class="lab">Afternoon Pickup</div>
        <div class="time">3:30 – 4:00 PM</div>
        <ul>
          <li>Carpool is always at the location where your <strong>youngest sibling</strong> is registered</li>
          <li>Picking up someone <em>not</em> on your dashboard Carpool Form? Share that camper's <strong>Safe Word</strong> with the carpool team to release them to you</li>
        </ul>
      </div>
    </div>
    <div class="cp-early reveal d2">
      <div class="cp-early-head">
        <div class="ic">⏰</div>
        <div>
          <div class="lab">Need to leave early?</div>
          <h3>Early Pickup</h3>
        </div>
        <div class="time">until 2:30 PM</div>
      </div>
      <ul>
        <li>Early pickup is available <strong>until 2:30 PM</strong> through Camp Reception</li>
        <li>Bring a <strong>valid government-issued photo ID</strong> and sign the <strong>release form</strong> at Reception</li>
        <li>If the person picking up is <strong>not immediate family</strong>, they must provide the camper's <strong>Safe Word</strong> to release the child</li>
      </ul>
    </div>
    <h3 class="reveal" style="margin-bottom:18px">3 Carpool Locations</h3>
    <div class="reveal">
      <div class="cp-tabs">
        <button class="cp-tab active" data-loc="1">📍 Scheck Family Plaza</button>
        <button class="cp-tab" data-loc="2">📍 Hillel</button>
        <button class="cp-tab" data-loc="3">📍 Savage Playground</button>
        <button class="cp-tab" data-loc="4">📍 ECA</button>
      </div>
      <div class="cp-legend">
        <span><i style="background:#0A57E0"></i>Plaza entry</span>
        <span><i style="background:#3FA876"></i>Playground entry</span>
        <span><i style="background:#FF4FB3"></i>ECA entry</span>
        <span><i style="background:#E04A4A"></i>Hillel entry</span>
        <span><i style="background:#FF8A1F"></i>Exit (all)</span>
        <span><i style="background:#FFC107;border-radius:50%"></i>Drop-off</span>
        <span><i style="background:#1FB6B6;border-radius:50%"></i>Gate</span>
      </div>
      <div class="cp-detail active" data-loc="1">
        <div class="cp-map cp-map-anim">
          <CarpoolAnim
            baseImage="/assets/scheck-map.png"
            alt="Scheck Family Plaza carpool route"
            viewBoxW={1192}
            viewBoxH={850}
            entryD="M 540 35 L 775 50 L 775 360 L 380 360 L 339 333"
            exitD="M 339 333 L 270 425 L 1020 425 L 1042 377"
            entryColor="#0A57E0"
            dropoff={{ x: 339, y: 333 }}
            gate={{ x: 1042, y: 377 }}
          />
        </div>
        <div><span class="badge">Location 1 · Plaza · Blue</span><h3>Scheck Family Plaza</h3><p>MARJCC main entrance. The primary carpool location with the highest throughput.</p><ul><li>Enter via the blue route from the main road</li><li>Drop off at the yellow circle</li><li>Exit through the gate (teal) along the orange route</li></ul></div>
      </div>
      <div class="cp-detail" data-loc="2">
        <div class="cp-map cp-map-anim">
          <CarpoolAnim
            baseImage="/assets/hillel-map.png"
            alt="Hillel carpool route"
            viewBoxW={1021}
            viewBoxH={805}
            entryD="M 154 191 L 146 233 L 142 274 L 137 316 L 134 358 L 130 400 L 126 441 L 121 483 L 124 525 L 127 566 L 129 608 L 132 650 L 158 669 L 199 670 L 241 670 L 283 671 L 324 672 L 366 673 L 408 673 L 450 674 L 491 675 L 609 674"
            exitD="M 609 674 L 533 676 L 491 675 L 449 674 L 407 673 L 365 673 L 323 672 L 282 671 L 240 670 L 198 670 L 157 669 L 132 649 L 129 607 L 127 565 L 124 524 L 122 482 L 126 440 L 130 399 L 134 357 L 138 315 L 142 273 L 147 232 L 181 177"
            entryColor="#E04A4A"
            dropoff={{ x: 609, y: 674 }}
            gate={{ x: 181, y: 177 }}
            gateLabel={{ dx: 28, dy: 6, anchor: 'start' }}
            dropoffLabel={{ dx: -130, dy: 6, anchor: 'start' }}
          />
        </div>
        <div><span class="badge">Location 2 · Hillel · Red</span><h3>Hillel</h3><p>[FILL IN: which camps drop off here]</p><ul><li>Enter via the red route</li><li>Drop off at the yellow circle</li><li>Exit through the gate (teal) along the orange route</li></ul></div>
      </div>
      <div class="cp-detail" data-loc="3">
        <div class="cp-map cp-map-anim">
          <CarpoolAnim
            baseImage="/assets/savage-map.png"
            alt="Savage Playground carpool route"
            viewBoxW={1192}
            viewBoxH={850}
            entryD="M 358 560 L 358 581 L 360 602 L 360 623 L 360 644 L 360 665 L 360 686 L 357 707 L 359 728 L 359 749 L 359 770 L 340 773 L 319 773 L 298 774 L 277 774 L 256 774 L 235 775 L 214 775 L 194 773 L 193 752 L 193 731 L 191 710 L 183 684"
            exitD="M 183 684 L 188 631 L 213 621 L 239 619 L 265 618 L 291 616 L 317 615 L 339 608 L 340 582 L 342 556 L 342 530 L 343 503 L 344 477 L 345 451 L 347 425 L 367 417 L 393 417 L 419 416 L 445 414 L 471 414 L 497 413 L 523 412 L 1042 377"
            entryColor="#3FA876"
            dropoff={{ x: 183, y: 684 }}
            gate={{ x: 1042, y: 377 }}
            dropoffLabel={{ dx: 26, dy: 6, anchor: 'start' }}
          />
        </div>
        <div><span class="badge">Location 3 · Playground · Green</span><h3>Savage Playground</h3><p>[FILL IN: which camps drop off here]</p><ul><li>Enter via the green route</li><li>Drop off at the yellow circle</li><li>Exit through the gate (teal) along the orange route</li></ul></div>
      </div>
      <div class="cp-detail" data-loc="4">
        <div class="cp-map cp-map-anim">
          <CarpoolAnim
            baseImage="/assets/eca-map.png"
            alt="ECA carpool route"
            viewBoxW={1192}
            viewBoxH={850}
            entryD="M 996 358 L 941 359 L 886 363 L 830 366 L 775 368 L 759 408 L 762 463 L 764 518 L 710 524 L 655 526 L 600 530 L 545 533 L 490 537 L 435 540 L 379 544 L 356 584 L 350 639 L 332 682 L 277 685 L 221 688 L 213 640 L 238 583"
            exitD="M 238 583 L 215 584 L 213 639 L 221 689 L 276 686 L 331 682 L 350 640 L 356 584 L 378 544 L 433 541 L 489 537 L 544 534 L 599 531 L 654 526 L 710 524 L 764 519 L 762 464 L 760 408 L 775 369 L 830 366 L 885 364 L 1042 377"
            entryColor="#FF4FB3"
            dropoff={{ x: 238, y: 583 }}
            gate={{ x: 1042, y: 377 }}
          />
        </div>
        <div><span class="badge">Location 4 · ECA · Pink</span><h3>ECA</h3><p>[FILL IN: which camps drop off here]</p><ul><li>Enter via the pink route</li><li>Drop off at the yellow circle</li><li>Exit through the gate (teal) along the orange route</li></ul></div>
      </div>
    </div>
    <div class="cp-req reveal"><div class="ic">📋</div><div><h3>Required for entry</h3><p><strong>Hang tag</strong> on your mirror + <strong>Carpool Form</strong> on your dashboard. Both distributed at T-Shirt Distribution Day, June 3, 2026, 4:00–7:30 PM, JCC Gym.</p></div></div>
  </div>
</section>
