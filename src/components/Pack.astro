<section class="section pack" id="pack">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow yellow">Pack smart</span>
      <h2>What to <span class="mark">bring.</span></h2>
      <p>Label everything. Bring what you need. Leave the rest at home. Tap items to check them off — your progress is saved.</p>
    </div>
    <div class="pack-grid">
      <div class="pack-col art reveal">
        <img src="/assets/sunny-pack.png" alt="Sunny packing his backpack with goggles, towel, water bottle and sunblock" loading="lazy" />
      </div>
      <div class="pack-col bring reveal d1">
        <div class="ih">✓</div><h3>Pack daily</h3>
        <div id="bringList">
          <div class="pitem"><input type="checkbox" id="b1" /><label for="b1">Camp t-shirt (worn each day)</label></div>
          <div class="pitem"><input type="checkbox" id="b2" /><label for="b2">Bathing suit (one-piece for swim days)</label></div>
          <div class="pitem"><input type="checkbox" id="b3" /><label for="b3">Towel</label></div>
          <div class="pitem"><input type="checkbox" id="b4" /><label for="b4">Sneakers — closed-toe, always</label></div>
          <div class="pitem"><input type="checkbox" id="b5" /><label for="b5">Water bottle (labeled with name)</label></div>
          <div class="pitem"><input type="checkbox" id="b6" /><label for="b6">Change of clothing</label></div>
          <div class="pitem"><input type="checkbox" id="b7" /><label for="b7">Sunblock — labeled with name</label></div>
          <div class="pitem"><input type="checkbox" id="b9" /><label for="b9">Backpack (labeled)</label></div>
        </div>
        <div class="pprog"><span style="font-size:13px;font-weight:700;color:var(--ink-soft)">PROGRESS</span><div class="bar"><div class="fill" id="bFill"></div></div><span class="pct" id="bPct">0%</span></div>
      </div>
      <div class="pack-col no reveal d2">
        <div class="ih">✕</div><h3>Do not bring</h3>
        <div class="pitem"><input type="checkbox" disabled /><label>Cellphones (no camper cell phone use)</label></div>
        <div class="pitem"><input type="checkbox" disabled /><label>Tablets, laptops, video games</label></div>
        <div class="pitem"><input type="checkbox" disabled /><label>Smartwatches with messaging</label></div>
        <div class="pitem"><input type="checkbox" disabled /><label>Money or valuables</label></div>
        <div class="pitem"><input type="checkbox" disabled /><label>Trading cards / collectibles</label></div>
        <div class="pitem"><input type="checkbox" disabled /><label>Toy weapons, fireworks, real weapons</label></div>
        <div class="pitem"><input type="checkbox" disabled /><label>Tobacco, alcohol, drugs, vape products</label></div>
      </div>
    </div>
  </div>
</section>
